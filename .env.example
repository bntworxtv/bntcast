# BNTcast Configuration
# Copy this file to .env and modify as needed

# ============================================================
# Server Settings
# ============================================================
PORT=3001
NODE_ENV=production

# ============================================================
# Database
# ============================================================
# SQLite database path (relative to server directory or absolute)
DATABASE_URL=file:./dev.db

# ============================================================
# Security
# ============================================================
# IMPORTANT: Change this to a random secret in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret

# ============================================================
# Media Storage
# ============================================================
# Directory for uploaded audio files
MEDIA_DIR=./media

# ============================================================
# Streaming Engines
# ============================================================
# SHOUTcast DNAS v2
SHOUTCAST_PORT_START=8001
SHOUTCAST_PORT_END=8100

# Icecast 2
ICECAST_PORT=8000
ICECAST_SOURCE_PASSWORD=hackme
ICECAST_ADMIN_PASSWORD=hackme

# ============================================================
# Docker Settings
# ============================================================
# HTTP_PORT=80
# HTTPS_PORT=443
