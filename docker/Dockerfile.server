FROM node:20-slim

RUN apt-get update && apt-get install -y ffmpeg icecast2 openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app/server

COPY server/package*.json ./
RUN npm install

COPY server/ ./
RUN npx prisma generate && npx tsc

RUN mkdir -p /app/media /app/config

EXPOSE 3001 8001-8100

CMD ["sh", "-c", "npx prisma db push --accept-data-loss && npx tsx src/seed.ts && node dist/index.js"]
